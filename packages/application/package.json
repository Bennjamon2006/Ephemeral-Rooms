{
  "name": "application",
  "version": "0.0.0",
  "description": "Application layer for the Ephemeral Rooms project",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "author": "Benjamin Rivas <benjaminrivas500@gmail.com>",
  "license": "MIT",
  "type": "module",
  "private": true,
  "exports": {
    "./use-cases": {
      "import": "./dist/lib/use-cases/index.js",
      "require": "./dist/lib/use-cases/index.js",
      "types": "./dist/lib/use-cases/index.d.ts"
    },
    "./messaging": {
      "import": "./dist/lib/messaging/index.js",
      "require": "./dist/lib/messaging/index.js",
      "types": "./dist/lib/messaging/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsc -w & tsc-alias -w",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "shared": "file:../shared"
  }
}
